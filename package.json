{
	"name": "project",
	"version": "0.1.0",
	"description": "SASS compile|autoprefix|minimize and live-reload dev server using Browsersync for static HTML",
	"main": "dist/index.html",
	"author": "5t3ph",
	"scripts": {
		"build:sass": "sass  --no-source-map src/sass:dist/css",
		"copy:assets": "copyfiles -u 1 ./src/assets/**/* dist",
		"copy:javascript": "copyfiles -u 1 ./src/js/*.js dist",
		"copy:html": "copyfiles -u 1 ./src/*.html dist",
		"copy": "npm-run-all --parallel copy:*",
		"build": "npm-run-all copy:* build:*",
		"postbuild": "postcss dist/css/*.css -u autoprefixer cssnano -r --no-map"
	},
	"dependencies": {
		"autoprefixer": "^10.4.2",
		"copyfiles": "^2.4.1",
		"cssnano": "^5.0.17",
		"npm-run-all": "^4.1.5",
		"postcss-cli": "^9.1.0",
		"sass": "^1.49.8"
	}
}
